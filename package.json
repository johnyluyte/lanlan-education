{
  "name": "lanlan-education",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev:local": "nuxt dev --dotenv .env.dev.local --host",
    "dev:cloud": "nuxt dev --dotenv .env.dev.cloud --host",
    "generate": "nuxt generate --dotenv .env.prod --no-ssr",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "prettier --list-different --write . && eslint . --fix",
    "typecheck": "nuxt typecheck",
    "check": "node scripts/check-alias-sync.mjs && nuxt typecheck && prettier --list-different --write . && eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "nuxt": "^4.4.8",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "@iconify-json/lucide": "^1.2.112",
    "@nuxt/test-utils": "4.0.3",
    "@nuxt/ui": "^4.8.2",
    "@nuxtjs/i18n": "10.4.0",
    "@pinia/nuxt": "0.11.3",
    "@supabase/supabase-js": "2.108.1",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.3.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.60.0",
    "@types/sortablejs": "^1.15.9",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.3",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0"
}
