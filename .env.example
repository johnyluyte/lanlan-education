##
## Nuxt.js 專用
##

NUXT_PORT=3001

##
## Supabase 專用
##

# Supabase (publishable key — safe for client/SPA; NOT the sb_secret_ key)
NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

##
## 其他環境變數
##

NUXT_PUBLIC_CURRENT_ENV=dev/stage/prod
